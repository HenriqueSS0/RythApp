# ==============================================================================
# GitHub Linguist Configuration
# Defines how repository language statistics are calculated for the codebase.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Vendored & Generated Content
# Exclude map data, assets, and lockfiles from language metrics.
# ------------------------------------------------------------------------------
stars/** linguist-vendored
*.json linguist-vendored
*.lock linguist-vendored
*.svg linguist-vendored

# ------------------------------------------------------------------------------
# 2. Auxiliary Configurations
# Exclude runtime config scripts and generic styles to prevent 'Other' grouping.
# ------------------------------------------------------------------------------
*.mjs linguist-detectable=false
*.js linguist-detectable=false
*.css linguist-detectable=false
*.html linguist-detectable=false

# ------------------------------------------------------------------------------
# 3. Core Stack Enforcement
# Explicitly map source files to our primary technologies (Next.js & Tauri).
# ------------------------------------------------------------------------------
*.ts linguist-language=TypeScript
*.tsx linguist-language=TypeScript
*.rs linguist-language=Rust
